{
  "name": "aa",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/app/electron/main.js",
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.json",
    "start": "electron .",
    "cli": "tsx cli.ts",
    "cli:dist": "node dist/cli.js",
    "smoke:tavily": "tsx tests/tavily-web-search.smoke.ts",
    "smoke:youtube-transcribe": "tsx tests/youtube-transcribe.smoke.ts",
    "smoke:whisper": "tsx tests/whisper.smoke.ts",
    "smoke:embedding-vector-store": "tsx tests/embedding-vector-store.smoke.ts",
    "electron:packed": "npm run build && electron .",
    "dev": "npm run build && concurrently -k \"tsc -w -p tsconfig.json\" \"wait-on dist/app/electron/main.js dist/services/llm.js && electron .\"",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-rebuild": "^3.2.9",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.10.0",
    "sqlite-vec": "^0.1.9",
    "youtube-transcript": "^1.3.1"
  }
}
